//nested if-else 
//program 3

#include<iostream>
using namespace std;

int main(){
    int age;
    cin>>age;
    
    if(age>=18){
        if(age>=100){
            cout<<"eligible for vote(but we are super senior citizen)";
        }else{
            cout<<"eligible for vote";
        }
    }else{
        if(age < 0){
            cout<<"enter a valid age number";
        }else{
            cout<<"not eligible for vote";
        }
    }
    return 0;
}

