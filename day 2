//continue statement 
//program-5
//print 1 to n and avoid those num.divide by 3


#include<iostream>
using namespace std;

int main(){
    int n;
    cin>>n;
    
    for(int i=1; i<=n; i++){
        if(i%3 == 0){
            continue;
        }
        cout<<i<<endl;
    }
    return 0;
}

//break statement 
//program-6
//we have to add num. until we get a negative num.


#include<iostream>
using namespace std;

int main(){
    int n;
    int sum = 0;

    while(true){
        cin>>n;

        if(n < 0){
            break;
        }
        sum = sum + n;
    }
    cout<<sum;
    return 0;
}
