program - 6
PRINT 10 TO 1 USING DO while LOOP
#include <iostream>
using namespace std;

int main(){
    int i = 10;
    do{
        cout<<i<<endl;
        i--;
    }while(i>=1);
    return 0;
}

// program - 7
// factorial n number 
#include <iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    int fact = 1;
    
    for(int i = n; i>= 1; i--){
        fact = fact * i;
    }
    cout << fact;
    return 0;
}
