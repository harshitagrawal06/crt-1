//program - 1
//PRINT 1 TO 10 USING A FOR LOOP
#include <iostream>
using namespace std;

int main() {
    for(int i = 1; i<=10; i++){
        cout<<i<<endl;
    }
    return 0;
}



//program - 2
//PRINT 10 TO 1 USING A FOR LOOP
#include <iostream>
using namespace std;

int main() {
    for(int i = 10; i>=1; i--){
        cout<<i<<endl;
    }
    return 0;
}
